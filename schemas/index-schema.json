{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge Library Index",
  "description": "Machine-readable catalog of all agents, skills, and templates in the Forge library",
  "type": "object",
  "required": ["version", "updated", "agents", "skills", "templates"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version number",
      "const": 1
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last index update"
    },
    "agents": {
      "type": "array",
      "description": "All agent definitions in the library",
      "items": {
        "type": "object",
        "required": ["name", "domain", "path", "tags", "quality"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique agent identifier in kebab-case"
          },
          "domain": {
            "type": "string",
            "description": "Primary domain category"
          },
          "path": {
            "type": "string",
            "description": "Relative path from library/ to the agent definition file"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 3,
            "description": "Searchable keywords for matching"
          },
          "quality": {
            "type": "string",
            "enum": ["untested", "tested", "iterated", "curated"],
            "description": "Lifecycle quality stage"
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "All skill definitions in the library",
      "items": {
        "type": "object",
        "required": ["name", "domain", "path", "tags"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "domain": { "type": "string" },
          "path": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "description": "All team templates in the library",
      "items": {
        "type": "object",
        "required": ["name", "domain", "path", "roles"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "domain": { "type": "string" },
          "path": { "type": "string" },
          "roles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Agent names referenced by this template"
          }
        }
      }
    }
  }
}
